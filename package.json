{
  "name": "hockey-predictor",
  "version": "1.0.0",
  "description": "KHL match prediction with statistics, correlation analysis and regression models",
  "main": "dist/pipeline.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/pipeline.js",
    "dev": "tsx src/pipeline.ts",
    "collect": "tsx src/data/collect/fetchMatches.ts",
    "lint:types": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "khl",
    "hockey",
